{
  "name": "class-war-international",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "web": "npm run start --workspace=web",
    "server": "npm run start --workspace=server",
    "generate": "node --experimental-strip-types scripts/generate-cards.ts",
    "test": "npm run test --workspace=web",
    "test:watch": "npm run test:watch --workspace=web",
    "test:e2e": "npm run test:e2e --workspace=web",
    "typecheck": "tsc -p tsconfig.scripts.json && npm run typecheck --workspace=web && npm run typecheck --workspace=server",
    "lint": "npm run lint --workspace=web"
  }
}
